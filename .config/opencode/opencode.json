{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": ["./AGENTS.md"],
  "default_agent": "build",
  "share": "disabled",
  // "enabled_providers": ["openrouter", "google", "anthropic"],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".turbo/**",
      ".git/**",
      "coverage/**",
      ".cache/**",
      "out/**"
    ]
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "timeout": 60000,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": false,
      "headers": {
        "EXA_API_KEY": "{env:EXA_API_KEY}"
      },
      "timeout": 60000,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check"
    },
    "mgrep": {
      "command": ["mgrep", "mcp"],
      "enabled": true,
      "type": "local"
    },
    "next-devtools": {
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": false,
      "timeout": 60000,
      "type": "local"
    },
    "web-reader": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      },
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp"
    },
    "web-search-prime": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      },
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp"
    },
    "zai-mcp-server": {
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "enabled": false,
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      },
      "timeout": 60000,
      "type": "local"
    }
  },
  // "model": "openrouter/essentialai/rnj-1-instruct",
  // "small_model": "openrouter/mistralai/mistral-nemo",
  "permission": {
    "edit": "ask",
    "write": "ask",
    "webfetch": "allow",
    "bash": {
      "ls *": "allow",
      "cat *": "allow",
      "pwd": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "*": "ask"
    }
  },
  "plugin": [
    "opencode-gemini-auth@latest",
    "opencode-claude-auth",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@nick-vi/opencode-type-inject@1.3.1",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@tarquinen/opencode-dcp@3.1.5",
    "@mohak34/opencode-notifier@latest"
  ],
  "provider": {
    "google": {
      "whitelist": [
        "gemini-2.5-flash",
        "gemini-2.5-pro",
        "gemini-3-flash-preview",
        "gemini-3-pro-preview"
      ]
    },
    "openrouter": {
      "name": "OpenRouter",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "essentialai/rnj-1-instruct": {
          "name": "RNJ-1 Instruct",
          "limit": {
            "context": 32768,
            "output": 4096
          },
          "options": {
            "provider": {
              "allow_fallbacks": false
            }
          }
        }
      }
    }
  },
  "snapshot": false,
  "theme": "solarized-osaka",
  "tui": {
    "diff_style": "auto",
    "scroll_acceleration": {
      "enabled": true
    },
    "scroll_speed": 5
  },
  "username": "limaon"
}
