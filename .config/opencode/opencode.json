{
  "$schema": "https://opencode.ai/config.json",
  "username": "limaon",
  "default_agent": "Build",
  "theme": "solarized-osaka",
  "autoupdate": true,
  "snapshot": false,
  "instructions": ["./AGENTS.md"],
  "plugin": [
    "opencode-gemini-auth@latest",
    "@nick-vi/opencode-type-inject@1.3.1",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "tui": {
    "scroll_speed": 5,
    "scroll_acceleration": {
      "enabled": true
    },
    "diff_style": "auto"
  },
  "permission": {
    "*": "ask"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true,
      "timeout": 60000
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": { "Authorization": "Bearer {env:Z_AI_API_KEY}" },
      "enabled": true
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": { "Authorization": "Bearer {env:Z_AI_API_KEY}" },
      "enabled": true
    },
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      },
      "enabled": true,
      "timeout": 60000
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check",
      "enabled": false,
      "timeout": 60000,
      "headers": { "EXA_API_KEY": "{env:EXA_API_KEY}" }
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "timeout": 60000
    },
    "mgrep": {
      "type": "local",
      "command": ["mgrep", "mcp"],
      "enabled": true
    }
  },
  "provider": {
    "cliproxy": {
      "models": {
        "gemini-claude-opus-4-5-thinking": {
          "name": "Claude Opus 4.5 Thinking [VibeDev ID]",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "textVerbosity": "none"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high"
            }
          }
        },
        "gemini-claude-sonnet-4-5-thinking": {
          "name": "Claude Sonnet 4.5 Thinking [VibeDev ID]",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "textVerbosity": "none"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high"
            }
          }
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview [Antigravity]",
          "reasoning": true,
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "cost": {
            "input": 2,
            "output": 12,
            "cache_read": 0.2
          },
          "modalities": {
            "input": ["text", "image", "video", "audio", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "textVerbosity": "none"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high"
            }
          }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview [Antigravity]",
          "modalities": {
            "input": ["text", "image", "pdf", "video"],
            "output": ["text"]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "textVerbosity": "none"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high"
            }
          }
        }
      }
    }
  }
}
