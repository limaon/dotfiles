# load Xresources
xrdb -merge "${HOME}/.config/x11/Xresources"

# set wallpaper
# nitrogen --set-scaled --random /home/void/Pictures/Wallpapers
nitrogen --restore --set-scaled &

# Network Manager Applet
nm-applet &

# Bluetooth systray icon
blueman-applet &

# Compositor
picom &

# Hide mouse when typing
xbanish &

# start redshift
redshift &

# start nitification
dunst &

# Monitor Config
xrandr --output eDP-1 --primary --mode 1366x768 --pos 0x0 --rotate normal --output HDMI-1 --off

# Speedy keys | Option "AutoRepeat" "300 50" on 40-libinput.conf
# xset r rate 300 50 &

# time to suspend screen
xset s 300 300 &
xset dpms 300 600 600 &

# Run localectl set-x11-keymap us '' '' caps:escape

#Search for: Make xinput settings permanent after boot
xinput set-prop "06CB0301:00 06CB:CD41 Touchpad" "libinput Natural Scrolling Enabled" 1 &
xinput set-prop "06CB0301:00 06CB:CD41 Touchpad" "libinput Tapping Enabled" 1 &

ssh-agent "${WM:-i3}"
