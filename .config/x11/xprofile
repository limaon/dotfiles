#!/bin/sh

# load Xresources
xrdb -merge "${HOME}/.config/x11/Xresources"

# set wallpaper
# feh --bg-fill --randomize ~/Pictures/backgrounds/* &
# nitrogen --set-scaled --random /home/void/Pictures/Wallpapers
nitrogen --restore --set-scaled &

# Network Manager Applet
# nm-applet --indicator &
nm-applet &

# Bluetooth systray icon
blueman-applet &

# Compositor
# picom & disowm

# Hide mouse when typing
xbanish &

# start redshift
redshift & disowm

# Gnome polkit
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 & disowm

# Monitor Config
xrandr --output eDP-1 --off --output HDMI-1 --primary --mode 1920x1080 --pos 0x0 --rotate normal

# zsh config dir
# export ZDOTDIR=$HOME/.config/zsh

eval $(ssh-agent)
