# i3 config file
# This is our mod Key. Currently it is set to the Windows Key.
set $alt                Mod1
set $super              Mod4
set $mod                Mod4

# Variables for directions
set $up                 k
set $down               j
set $left               h 
set $right              l

# Exec vars
set $execute            exec --no-startup-id
set $always_exec        exec_always --no-startup-id

# Scripts path
set $bin_path           ~/.local/bin

# Remove title bar (border)
default_border          pixel 1
default_floating_border normal
for_window [all]        border pixel 1

# Ex: popup_during_fullscreen smart|ignore|leave_fullscreen
popup_during_fullscreen smart

# Hide_borders
hide_edge_borders       smart

# Window focus follows mouse movements by default
focus_follows_mouse	    yes

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
font pango:             Hack Nerd Font Mono, FontAwesome, Noto Sans Mono CJK JP 9

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier       $mod

# start a terminal. We use kitty.
bindsym $mod+Return     $execute i3-sensible-terminal

# kill focused window
bindsym $mod+Shift+q    kill

# start dmenu (a program launcher).
bindsym $mod+d          $execute i3-dmenu-desktop --dmenu="dmenu -i -l 4 -fn 'TerminessTTF Nerd Font' -p 'Open:'"

# This should only be used if a program lacks a .desktop file.
bindsym $mod+Shift+d    $execute rofi -show run

# Web search 
bindsym $mod+b          $execute ~/.config/rofi/scripts/rofi-search.sh

# Edit configs by rofi
bindsym $alt+c          $execute ~/.config/rofi/scripts/rofi-edit-configs.sh

# Cabl (primary)
bindsym $mod+c			    $execute $bin_path/cabl

# Open clipboard content with rofi dmenu
bindsym $mod+Shift+v	  $execute $bin_path/cabl clip

# Toggle window border
bindsym $mod+Shift+w		border toggle

# workspace back and forth (with/without active container)
workspace_auto_back_and_forth yes
bindsym $mod+n          workspace back_and_forth
bindsym $mod+Shift+n    move container to workspace back_and_forth; workspace back_and_forth

# split in horizontal and vertical orientation
bindsym $mod+semicolon split toggle

# enter fullscreen mode for the focused container
bindsym $mod+F11        fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s          layout stacking
bindsym $mod+w          layout tabbed
bindsym $mod+e          layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle resize set 670 600

# change focus between tiling / floating windows
bindsym $mod+space      focus mode_toggle

# Move focus to the parent/child container
bindsym $mod+a          focus parent
bindsym $mod+Shift+a    focus child

# Move for all workspaces
bindsym $mod+Ctrl+Right workspace next
bindsym $mod+Ctrl+Left  workspace prev

# Launcher tmux session
bindsym $mod+Shift+Return	    exec --no-startup-id i3-sensible-terminal -e tmux

# reload the configuration file
bindsym $mod+Shift+c reload

# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

# Hide / unhide i3status bar
bindsym $mod+m bar mode toggle

# Hover: move window to bottom right/left
bindsym $mod+Shift+apostrophe	floating toggle; sticky toggle; exec --no-startup-id hover right
bindsym $mod+Shift+semicolon	floating toggle; sticky toggle; exec --no-startup-id hover left

# List open windows to switch to
bindsym $alt+Tab		exec rofi -show window

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"

# switch to workspace
bindsym $mod+1              workspace $ws1
bindsym $mod+2              workspace $ws2
bindsym $mod+3              workspace $ws3
bindsym $mod+4              workspace $ws4
bindsym $mod+5              workspace $ws5
bindsym $mod+6              workspace $ws6
bindsym $mod+7              workspace $ws7
bindsym $mod+8              workspace $ws8
bindsym $mod+9              workspace $ws9

# move focused container to workspace
bindsym $mod+Shift+1        move container to workspace $ws1 
bindsym $mod+Shift+2        move container to workspace $ws2 
bindsym $mod+Shift+3        move container to workspace $ws3 
bindsym $mod+Shift+4        move container to workspace $ws4 
bindsym $mod+Shift+5        move container to workspace $ws5 
bindsym $mod+Shift+6        move container to workspace $ws6 
bindsym $mod+Shift+7        move container to workspace $ws7 
bindsym $mod+Shift+8        move container to workspace $ws8 
bindsym $mod+Shift+9        move container to workspace $ws9 

# change focus
bindsym $mod+$left          focus left
bindsym $mod+$down          focus down
bindsym $mod+$up            focus up
bindsym $mod+$right         focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left           focus left
bindsym $mod+Down           focus down
bindsym $mod+Up             focus up
bindsym $mod+Right          focus right

# move focused window
bindsym $mod+Shift+$left    move left
bindsym $mod+Shift+$down    move down
bindsym $mod+Shift+$up      move up
bindsym $mod+Shift+$right   move right

# move a workspace around monitors
bindsym $mod+Ctrl+$left		  move workspace to output left
bindsym $mod+Ctrl+$down		  move workspace to output down
bindsym $mod+Ctrl+$up		    move workspace to output up
bindsym $mod+Ctrl+$right	  move workspace to output right

# scratchpad feature
bindsym $mod+BackSpace	            scratchpad show
bindsym $mod+Shift+BackSpace	      move scratchpad
for_window [instance="scratchpad"]  move window to scratchpad, scratchpad show

# Set floating for apps needing it
for_window [instance="blueman-manager"]                     floating enable 
for_window [title="(?i) - Anki"]                            floating enable, border pixel 2
for_window [class="(?i)anki" title="Edit Current"]          floating enable, border pixel 1
for_window [class="(?i)anki" title="Statistics"]            floating enable, border pixel 1
for_window [class="(?i)anki" title="Browse"]                move to workspace $ws9, border normal 2
for_window [class="mpv"]			                              move position center, border pixel 2, focus
for_window [class="Nm-connection-editor"]	                  floating enable, border normal 3
for_window [instance="qalculate-gtk"]                       floating enable, border pixel 3, resize set 400 200
for_window [class="Pavucontrol"]		                        floating enable, border normal 3
for_window [class="^Lx.*"]			                            floating enable, border normal 3
for_window [class="Nitrogen"]                               floating enable, border normal 
for_window [class="GParted"]                                floating enable, border normal
for_window [class="System-config-printer.py"]               floating enable, resize set 480 280, border normal
for_window [class="Arandr"]                                 floating enable, resize set 600 480, border normal
for_window [class="Polkit-gnome-authentication-agent-1"]    floating enable, sticky enable border normal
for_window [class="transmission-gtk"]                       floating enable, border normal 2
for_window [class="feh"]                                    floating enable, border normal
for_window [class="fcitx5-config-qt"]                       floating enable, border pixel 3


for_window [window_role="About"]                    floating enable
for_window [window_role="splash"]                   floating enable
for_window [window_type="dialog"]		                floating enable
for_window [window_type="(?i)menu"]		              floating enable
for_window [window_role="(?i)task_dialog"] 	        floating enable
for_window [window_role="(?i)pop-up"]		            floating enable
for_window [window_role="(?i)preferences"] 	        floating enable
for_window [window_role="(?i)about"] 		            floating enable
for_window [window_role="GtkFileChooserDialog"]     resize set 800 600
for_window [window_role="GtkFileChooserDialog"]     move position center


for_window [title="^Preferences$"]      floating enable
for_window [title="Copying"]            floating enable
for_window [title="Deleting"]           floating enable
for_window [title="Moving"]             floating enable
for_window [title="File Transfer*"]     floating enable
for_window [title="File Operation*"]    floating enable
for_window [title="^Page Info"]			    floating enable, border normal 3
for_window [title="WebP viewer"]		    floating enable, move position center

# set position of floating window
for_window [all]                 move absolute position center

# Open and focus to specific workspace
#assign [class="(?i)firefox"]                  $ws1
assign [class="transmission-gtk"]             $ws2
assign [class="Thunderbird"]                  $ws2
assign [class="obsidian"]                     $ws7
#assign [class="(?i)anki"]  		                $ws8

# Limitando o tamanho máximo da janela flutuante:
floating_minimum_size 10 x 10
floating_maximum_size 1048 x 720

# switch to workspace with urgent window autimaticaly
#for_window [urgent=latest] focus
focus_on_window_activation smart


# resize window (you can also use the mouse for that)
mode "resize" {

# These bindings trigger as soon as you enter the resize mode
  bindsym l       resize shrink width 5 px or 5 ppt
  bindsym k       resize grow height 5 px or 5 ppt
  bindsym j       resize shrink height 5 px or 5 ppt
  bindsym h       resize grow width 5 px or 5 ppt

# same bindings, but for the arrow keys
  bindsym Left    resize shrink width 10 px or 10 ppt
  bindsym Down    resize grow height 10 px or 10 ppt
  bindsym Up      resize shrink height 10 px or 10 ppt
  bindsym Right   resize grow width 10 px or 10 ppt

# back to normal: Enter or Escape or $mod+r
  bindsym Return  mode "default"
  bindsym Escape  mode "default"

}
bindsym $mod+r      mode "resize"

# Start i3bar to display a workspace bar (plus the system information i3status
bar {
  status_command i3status -c ~/.config/i3/i3status.conf
  font pango: TerminessTTF Nerd Font, FontAwesome 9
  strip_workspace_numbers yes
  tray_output primary
  position bottom
  tray_padding 3
}

# Auto startup aplications
$execute fcitx5 -dr 
$execute	thunar --daemon
$always_exec xset r rate 300 50
$always_exec nitrogen --restore

###### Power Menu (i3wm) ######
set $i3lockscreen dm-tool lock && sleep 1
set $mode_system (l)Lock, (e)Logout, (s)Suspend, (r)Reboot, (CTRL+s)Shutdown

mode "$mode_system" {

    bindsym l exec --no-startup-id $i3lockscreen, mode "default"
    bindsym e exec --no-startup-id i3-msg exit, mode "default"
    #bindsym s exec --no-startup-id $i3lockscreen && systemctl suspend, mode "default"
    bindsym s exec --no-startup-id systemctl suspend, mode "default"
    bindsym r exec --no-startup-id systemctl reboot -i, mode "default"
    bindsym Ctrl+s exec --no-startup-id systemctl poweroff -i, mode "default"

    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"

}
bindsym $mod+Shift+e mode "$mode_system"

### Monitor setup (i3wm) #####
set $mode_display (d)Hdmi, (t)Notebook, (a)DMonitor, (v)DV_Monitor

mode "$mode_display" {

    bindsym d $execute xrandr --output eDP-1 --off --output HDMI-1 --primary --mode 1920x1080 --pos 0x0 --rotate normal, mode "default"
    bindsym t $execute xrandr --output eDP-1 --primary --mode 1366x768 --pos 0x0 --rotate normal --output HDMI-1 --off, mode "default"
    bindsym a $execute xrandr --output eDP-1 --mode 1366x768 --pos 0x0 --rotate normal --output HDMI-1 --primary --mode 1920x1080 --pos 1366x0 --rotate normal, mode "default"
    bindsym v $execute xrandr --output eDP-1 --primary --mode 1366x768 --pos 0x280 --rotate normal --output HDMI-1 --mode 1920x1080 --pos 1366x0 --rotate left, mode "default"

    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+x mode "$mode_display"

### Share attachments (i3wm) ###
set $share_attach  (q) , (w) , (e)AudioAnki, (r)SentAnki, (t)ShotAnki

mode "$share_attach" {
  bindsym q --release $execute $bin_path/mediaExtractor.sh colorpicker, mode "default"
  bindsym w $execute $bin_path/mediaExtractor.sh InternalAudio, mode "default"
  bindsym e $execute ~/.local/bin/ames.sh -r
  bindsym r $execute ~/.local/bin/ames.sh -c, mode "default"
  bindsym t $execute ~/.local/bin/ames.sh -s, mode "default"

  # back to normal: Enter or Escape
  bindsym Return mode "default"
  bindsym Escape mode "default"
}
bindsym $mod+Insert mode "$share_attach"

# Stop ffmpeg
bindsym $mod+Delete $execute $bin_path/mediaExtractor.sh

# ScreenShot menu
bindsym --release $mod+Pause $execute $bin_path/maimpick
bindsym --release Print $execute $bin_path/maimpick full

# Open Calculator
bindsym XF86Calculator		$execute qalculate-gtk

# Audio
bindsym XF86AudioRaiseVolume $execute $bin_path/volume high
bindsym XF86AudioLowerVolume $execute $bin_path/volume medium
bindsym XF86AudioMute        $execute $bin_path/volume muted

# Player Control
bindsym XF86AudioPlay       $execute mpc toggle
bindsym XF86AudioPause      $execute mpc pause
bindsym XF86AudioStop       $execute mpc stop
bindsym XF86AudioNext       $execute mpc next
bindsym XF86AudioPrev       $execute mpc previous
bindsym XF86AudioMedia		  $execute i3-sensible-terminal -e ncmpcpp

# File Manager
bindsym XF86Explorer		    $execute i3-sensible-terminal --title 'File Manager' -e $bin_path/lfub


#Brightness Control
bindsym XF86MonBrightnessUp exec --no-startup-id $bin_path/brightness up
bindsym XF86MonBrightnessDown exec --no-startup-id $bin_path/brightness down
