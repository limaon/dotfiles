#!/usr/bin/env bash

# Script Name: NCMPcpp Notification Script
# Description: This script is used to enhance the NCMPcpp (a CLI music player) experience by generating 
#              notifications for the currently playing track. It fetches the details of the current track 
#              playing in NCMPcpp, generates a preview image of the album (if it doesn't already exist), 
#              and sends a notification displaying the track title, artist, and album name along with the 
#              album preview image.
# Usage:       This script can be set up to run periodically or be triggered by an event in your music player setup.
# Author:      Alvaro Oliveira
# Date:        14-09-2023
# Version:     1.0

# Configuration
music_dir="$HOME/Music"
preview_dir="$XDG_CONFIG_HOME/ncmpcpp/previews"
notification_id=27072

# Ensure the preview directory exists
mkdir -p "$preview_dir"

# Get the current song details
filename="$(mpc --format "$music_dir"/%file% current)"
album_name="$(mpc --format %album% current)"
preview_name="$preview_dir/$(echo -n "$album_name" | base64).png"

# Function to generate preview image if it doesn't exist
generate_preview() {
  if [ ! -e "$preview_name" ]; then
    ffmpeg -y -i "$filename" -an -vf scale=128:128 "$preview_name" > /dev/null 2>&1
    if [ $? -ne 0 ]; then
      # echo "Error generating preview image."
      # Set a default image in case of error
      preview_name="audio-x-generic"
    fi
  fi
}

# Function to send notification
send_notification() {
  local title artist album
  title="$(mpc --format %title% current)"
  artist="$(mpc --format %artist% current)"
  album="$(mpc --format %album% current)"
  
  notify-send -r $notification_id "Now Playing" "$title \n$artist - $album" -i "$preview_name"
  if [ $? -ne 0 ]; then
    # echo "Error sending notification."
    exit 1
  fi
}

# Main script execution
generate_preview
send_notification
