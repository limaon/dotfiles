#!/bin/bash

function send_notification() {
    volume=$(pamixer --get-volume)
    dunstify -a "volume" -u low -r "9993" -h int:value:"$volume" -i "audio-volume-$1" "Volume: ${volume}%" -t 2000
}

case $1 in
high)
    # Set the volume on (if it was muted)
    # Parameter --allow-boost allow volume to go above 100%. (Ex. pamixer -i 5 --allow-boost)
    pamixer -u
    pamixer -i 5
    send_notification $1
    ;;
medium)
    pamixer -u
    pamixer -d 5 
    send_notification $1
    ;;
muted)
    pamixer -t
    if $(pamixer --get-mute); then
        dunstify -i volume-mute -a "volume" -t 2000 -r 9993 -u low "Volume Muted!" -i "audio-volume-$1"
    else
        send_notification high
    fi
    ;;
esac
#!/bin/bash

# Função para atualizar o volume
update_volume() {
  volume=$(pamixer --get-volume)
  status=$(pamixer --get-mute)

  if [ "$status" = "true" ]; then
    dunstify -u low -t 3000 -i audio-volume-muted -p "Volume: Muted"
  else
    dunstify -u low -t 3000 -i audio-volume-high -p "Volume: $volume%" -r $volume
  fi
}

case "$1" in
  "up")
    pamixer --increase 5
    update_volume
    ;;
  "down")
    pamixer --decrease 5
    update_volume
    ;;
  "toggle")
    pamixer --toggle-mute
    update_volume
    ;;
  *)
    echo "Uso: $0 up|down|toggle"
    exit 1
    ;;
esac
