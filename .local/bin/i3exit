#!/usr/bin/env bash

PICTURE="/tmp/i3lock.png"
SCREENSHOT_COMMAND="maim --hidecursor $PICTURE"
BLUR="5x4"
DBUS_DEST="org.freedesktop.login1"
DBUS_PATH="/org/freedesktop/login1"
DBUS_METHOD_BASE="org.freedesktop.login1.Manager"

take_screenshot() {
  $SCREENSHOT_COMMAND
  convert "$PICTURE" -blur $BLUR "$PICTURE"
}

lock() {
  take_screenshot
  sleep 1.5
  i3lock -efn -i "$PICTURE"
}

dbus-send-command() {
  local method="$DBUS_METHOD_BASE.$1"
  shift
  dbus-send --system --print-reply --dest="$DBUS_DEST" "$DBUS_PATH" "$method" "$@"
}

case "$1" in
  lock)
    lock
    ;;
  logout)
    i3-msg exit
    ;;
  suspend)
    dbus-send-command "Suspend" boolean:true
    lock
    ;;
  hibernate)
    dbus-send-command "Hibernate" boolean:true
    lock
    ;;
  reboot)
    dbus-send-command "Reboot" boolean:true
    ;;
  shutdown)
    dbus-send-command "PowerOff" boolean:true
    ;;
  *)
    echo "Usage: $0 {lock|logout|suspend|hibernate|reboot|shutdown}"
    exit 2
esac

exit 0
