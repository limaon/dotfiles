#!/usr/bin/env bash

# Function to display usage message
usage() {
  echo "Usage: $0 {up|down}"
  echo "  up   - Increase brightness by 5%"
  echo "  down - Decrease brightness by 5%"
  exit 1
}

# Check if necessary commands are available
command -v brillo >/dev/null 2>&1 || { echo >&2 "brillo command not found. Please install it first."; exit 1; }
command -v dunstify >/dev/null 2>&1 || { echo >&2 "dunstify command not found. Please install it first."; exit 1; }

# Function to send notification
send_notification() {
  local brightness
  brightness=$(printf "%.0f\n" $(brillo -G))
  if [[ $? -ne 0 ]]; then
    echo "Failed to get brightness."
    exit 1
  fi

  dunstify -a "brightness" -u low -r 9991 -h int:value:"$brightness" -i "xfpm-brightness-lcd" "Brightness: $brightness%" -t 2000
  if [[ $? -ne 0 ]]; then
    echo "Failed to send notification."
    exit 1
  fi
}

# Check if any argument is passed
if [[ -z $1 ]]; then
  usage
fi

# Main script logic
case $1 in
  up)
    pkexec /usr/bin/brillo -A 5 -p
    if [[ $? -ne 0 ]]; then
      echo "Failed to increase brightness."
      exit 1
    fi
    send_notification
    ;;
  down)
    pkexec /usr/bin/brillo -U 5 -p
    if [[ $? -ne 0 ]]; then
      echo "Failed to decrease brightness."
      exit 1
    fi
    send_notification
    ;;
  *)
    usage
    ;;
esac
