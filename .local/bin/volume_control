#!/usr/bin/env bash

# This script manages volume control and sends notifications accordingly.

function send_notification() {
  local volume=$(pamixer --get-volume)
  local icon="audio-volume-$1"
  local message="Volume: ${volume}%"

  if [[ $1 == "muted" ]]; then
    if pamixer --get-mute; then
      icon="audio-volume-muted"
      message="Volume Muted!"
    else
      icon="audio-volume-high"
    fi
  fi

  dunstify -a "volume" -u low -r "9993" -h int:value:"$volume" -i "$icon" "$message" -t 2000
}

function adjust_volume() {
  pamixer -u
  pamixer "$1" 5
  send_notification "$2"
}

case $1 in
  high)
    adjust_volume -i high
    ;;
  medium)
    adjust_volume -d medium
    ;;
  muted)
    pamixer -t
    send_notification muted
    ;;
  *)
    echo "Usage: $0 high|medium|muted"
    exit 1
    ;;
esac
