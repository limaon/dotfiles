#!/usr/bin/env bash

VOLUME_STEP=5
BRIGHTNESS_STEP=5
MAX_VOLUME=100
NOTIFICATION_TIMEOUT=1000
DOWNLOAD_ALBUM_ART=true
SHOW_ALBUM_ART=true
SHOW_MUSIC_IN_VOLUME_INDICATOR=true

# Get current volume level using pamixer
get_volume() {
    pamixer --get-volume
}

# Check if muted using pamixer
is_muted() {
    [[ $(pamixer --get-mute) == "true" ]]
}

# Get current brightness level using brillo
get_brightness() {
    pkexec /usr/bin/brillo | grep -Po '[0-9]{1,3}' | head -n 1
}

# Determine appropriate volume icon
get_volume_icon() {
    if is_muted; then
        echo "volume-level-muted"
    else
        case $1 in
            up) echo "volume-level-high";;
            down) echo "volume-level-medium";;
        esac
    fi
}

get_album_art() {
    url=$(playerctl -f "{{mpris:artUrl}}" metadata)
    album_art=""

    if [[ $url == "file://"* ]]; then
      album_art="${url/file:\/\//}"
    elif [[ $url == "http://"* ]] && [[ $DOWNLOAD_ALBUM_ART == "true" ]]; then
        # Identify filename from URL
        filename="$(echo "$url" | sed "s/.*\///")"

        # Download file to /tmp if it doesn't exist
        if [ ! -f "/tmp/$filename" ]; then
            wget -O "/tmp/$filename" "$url"
        fi

        album_art="/tmp/$filename"
    elif [[ $url == "https://"* ]] && [[ $DOWNLOAD_ALBUM_ART == "true" ]]; then
        # Identify filename from URL
        filename="$(echo "$url" | sed "s/.*\///")"
        
        # Download file to /tmp if it doesn't exist
        if [ ! -f "/tmp/$filename" ]; then
            wget -O "/tmp/$filename" "$url"
        fi

        album_art="/tmp/$filename"
    else
        album_art=""
    fi
}

# Display volume notification
show_volume_notification() {
    local volume=$(get_volume)
    local volume_icon=$(get_volume_icon $1)

    if [[ $SHOW_MUSIC_IN_VOLUME_INDICATOR == "true" ]]; then
        current_song=$(playerctl -f "<b>{{title}}</b>\n{{artist}}" metadata)
        get_album_art

        if [[ -z "$album_art" ]]; then
            icon="$volume_icon"
        else
            icon="$album_art"
        fi

        notify-send -u low -t $NOTIFICATION_TIMEOUT -h string:x-dunst-stack-tag:volume_notif -h int:value:"$volume" -i "$icon" "$volume%" "$current_song" -r "9993"
    else
        notify-send -u low -t $NOTIFICATION_TIMEOUT -h string:x-dunst-stack-tag:volume_notif -h int:value:"$volume" -i "$volume_icon" "$volume%" -r "9993"
    fi
}

# Display music notification
show_music_notification() {
    PLAYBACK_STATUS=$1
    NOTIFICATION_TIMEOUT=3000
    SONG_TITLE=$(playerctl -f "<b>{{title}}</b>" metadata)
    SONG_ARTIST=$(playerctl -f "<b>{{artist}}</b>\n" metadata)
    SONG_ALBUM=$(playerctl -f "{{album}}" metadata)

    if [[ $SHOW_ALBUM_ART == "true" ]]; then
        get_album_art
    fi

    notify-send -u low -t $NOTIFICATION_TIMEOUT -h string:x-dunst-stack-tag:music_notif -i "$album_art" "$PLAYBACK_STATUS: " "$SONG_TITLE by $SONG_ARTIST$SONG_ALBUM" -r "9993"
}

# Display brightness notification
show_brightness_notification() {
    local brightness=$(get_brightness)
    local brightness_icon="brightness-systray"
    notify-send -u low -t $NOTIFICATION_TIMEOUT -h string:x-dunst-stack-tag:brightness_notif -h int:value:"$brightness" -i "$brightness_icon" "$brightness%" -r "9993"
}

# Main control function
control_system() {
    case $1 in
        volume_up)
            pamixer --unmute
            pamixer --increase $VOLUME_STEP
            show_volume_notification "up"
            ;;
        volume_down)
            pamixer --decrease $VOLUME_STEP
            show_volume_notification "down"
            ;;
        volume_mute)
            pamixer --toggle-mute
            show_volume_notification
            ;;
        brightness_up)
            pkexec /usr/bin/brillo -A $BRIGHTNESS_STEP
            show_brightness_notification
            ;;
        brightness_down)
            pkexec /usr/bin/brillo -U $BRIGHTNESS_STEP
            show_brightness_notification
            ;;
        next_track)
            playerctl next
            sleep 0.5
            show_music_notification "Next Track"
            ;;
        prev_track)
            playerctl previous
            sleep 0.5
            show_music_notification "Previous Track"
            ;;
        play_pause)
            playerctl play-pause
            show_music_notification "Now Playing"
            ;;
    esac
}

control_system $1
